{
  "name": "lena-ae-app",
  "description": "TechSisters — plataforma web de mentoria em tecnologia para mulheres (projeto extensionista UNINTER)",
  "version": "0.0.1",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "dev:e2e": "E2E_DEV=1 __NEXT_TEST_MODE=1 next dev --webpack",
    "build": "prisma generate && next build",
    "start": "prisma generate &&next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma generate && prisma db seed",
    "e2e:install": "playwright install chromium",
    "e2e:clean": "node e2e/scripts/clean-output.mjs",
    "e2e:seed": "tsx e2e/seed/run-seed.ts",
    "e2e": "playwright test -c e2e/playwright.config.ts",
    "e2e:ui": "node e2e/scripts/run-ui.mjs",
    "e2e:ui:all": "node e2e/scripts/run-ui.mjs --all",
    "e2e:screenshots": "playwright test -c e2e/playwright.config.ts --project=screenshots",
    "e2e:demo": "playwright test -c e2e/playwright.config.ts --project=setup --project=demo-video e2e/specs/mvp-journey.spec.ts",
    "e2e:video": "playwright test -c e2e/playwright.config.ts --project=setup --project=demo-video e2e/specs/full-platform-tour.spec.ts && node e2e/scripts/copy-latest-video.mjs platform-tour.webm",
    "e2e:video:headed": "playwright test -c e2e/playwright.config.ts --project=setup --project=demo-video e2e/specs/full-platform-tour.spec.ts --headed && node e2e/scripts/copy-latest-video.mjs platform-tour.webm",
    "e2e:report": "playwright show-report e2e/output/report"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LenaMoromisato/lena-uninter-ae-app.git"
  },
  "keywords": [],
  "author": "Lena Moromisato <moromisato.lena@gmail.com>",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/LenaMoromisato/lena-uninter-ae-app/issues"
  },
  "homepage": "https://github.com/LenaMoromisato/lena-uninter-ae-app#readme",
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/postcss": "^4.3.1",
    "@tanstack/react-query": "^5.101.0",
    "@types/swagger-ui-react": "^5.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "postcss": "^8.5.15",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.79.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "swagger-ui-react": "^5.32.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.15.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "6.0.3"
  }
}
